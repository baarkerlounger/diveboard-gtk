{
    "app-id" : "xyz.slothlife.diveboard",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "40",
    "sdk" : "org.gnome.Sdk",
    "command" : "diveboard",
    "finish-args" : [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--system-talk-name=org.freedesktop.GeoClue2"
    ],
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules" : [
        {
		"name": "requests",
		"buildsystem": "simple",
		"build-options": {
		  "build-args": [
		    "--share=network"
		  ]
		},
		"build-commands": [
		    "pip3 install --prefix=/app --no-cache-dir requests"
		]
    	},
    	{
		"name": "xdg",
		"buildsystem": "simple",
		"build-options": {
		  "build-args": [
		    "--share=network"
		  ]
		},
		"build-commands": [
		    "pip3 install --prefix=/app --no-cache-dir xdg"
		]
    	},
        {
            "name" : "libchamplain",
            "buildsystem": "meson",
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://gitlab.gnome.org/GNOME/libchamplain.git"
                }
            ]
        },
        {
	  "name" : "libadwaita",
	  "buildsystem" : "meson",
	  "config-opts": [
	    "-Dexamples=false",
	    "-Dtests=false"
	  ],
	  "sources" : [
	    {
	      "type" : "git",
	      "url" : "https://gitlab.gnome.org/GNOME/libadwaita.git",
	      "branch" : "main"
	    }
	  ]
	},
        {
            "name" : "diveboard",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "dir",
                    "url" : "."
                }
            ]
        }
    ],
    "build-options" : {
        "env" : {        },
        # TODO remove when we upgrade to Gnome 41 and don't need to build libadwaita anymore
        "build-args": [
          "--share=network"
        ]
    }
}
